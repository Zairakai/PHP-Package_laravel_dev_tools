#!/usr/bin/env bash
# Pre-push hook - Full quality gate before pushing code
# Published by: zairakai/laravel-dev-tools
#
# To bypass (emergency only):
#   git push --no-verify

set -euo pipefail

# ANSI Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}  Pre-Push Quality Gate${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Navigate to project root (hooks run from .git/hooks or .githooks)
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
cd "$PROJECT_ROOT"

# Check if make is available
if ! command -v make &>/dev/null; then
    echo -e "${RED}❌ make not found - skipping quality checks${NC}"
    echo ""
    exit 0
fi

# Check if Makefile exists
if [[ ! -f "Makefile" ]]; then
    echo -e "${YELLOW}⚠️  No Makefile found - skipping quality checks${NC}"
    echo ""
    exit 0
fi

# Run full quality gate
echo -e "${BLUE}→${NC} Running: ${CYAN}make quality${NC}"
echo ""

if make quality; then
    echo ""
    echo -e "${GREEN}✅ Quality gate passed - push allowed${NC}"
    echo ""
    exit 0
else
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  ❌ Quality gate failed!${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}Fix issues with:${NC}"
    echo -e "  ${CYAN}make quality-fix${NC}  ${YELLOW}# Auto-fix what can be fixed${NC}"
    echo ""
    echo -e "${YELLOW}Or bypass (NOT recommended):${NC}"
    echo -e "  ${CYAN}git push --no-verify${NC}"
    echo ""
    exit 1
fi
